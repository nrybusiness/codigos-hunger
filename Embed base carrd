<div id="turno-box" style="text-align: center; padding: 20px; background: #fff3cd; border: 2px solid #ffeeba; border-radius: 12px; margin-bottom: 25px;">
<h3 style="margin: 0; color: #856404; font-family: sans-serif; font-size: 14px;">TU TURNO:</h3>
<h1 id="numero-turno" style="margin: 5px 0 0 0; color: #721c24; font-size: 42px; font-family: monospace; font-weight: bold;">#----</h1>
</div>

<style>
form .inner {
display: flex !important;
flex-direction: row !important;
flex-wrap: wrap !important;
justify-content: space-between !important;
align-items: flex-start !important;
}
form > .inner > .field { width: 100% !important; }
form > .inner > .field:has(input[type="checkbox"]) {
width: 48% !important;
margin-top: 5px !important;
min-height: 55px !important;
display: flex !important;
align-items: center !important;
}
.field label span.optional, .optional { display: none !important; }
</style>

<script>
(function() {
var numTurno = Math.floor(1000 + Math.random() * 9000);
var display = document.getElementById("numero-turno");
if (display) display.innerText = "#" + numTurno;

function inicializarCarrd() {
var form = document.querySelector('form');

// Inyección de Promo Dinámica en el Formulario
if (form && !document.querySelector('input[name="promo_papas_goat"]')) {
var promoInput = document.createElement('input');
promoInput.type = 'hidden';
promoInput.name = 'promo_papas_goat';
promoInput.value = 'on';
form.appendChild(promoInput);
}

// SOLUCIÓN RASTREO: Crear el campo turno_temp dinámicamente si no existe
var campoTurno = document.querySelector('input[name="turno_temp"], input[id^="turno_temp"]');
if (!campoTurno && form) {
campoTurno = document.createElement('input');
campoTurno.type = 'hidden';
campoTurno.name = 'turno_temp';
form.appendChild(campoTurno);
}
if (campoTurno) {
campoTurno.value = numTurno;
}

var selectorPersonas = document.querySelector('select[name="personas"]');

if (selectorPersonas && !selectorPersonas.dataset.configurado) {
selectorPersonas.dataset.configurado = "true";

function actualizarBloques() {
var val = selectorPersonas.value;
var esBatallon = (val === "+");
var n = esBatallon ? 0 : (parseInt(val) || 0);
var mostrarExtras = (n >= 1 && n <= 5 && !esBatallon);

function alternarVisibilidad(el, mostrar) {
if (!el) return;
if (mostrar) {
el.style.removeProperty('display');
} else {
el.style.setProperty('display', 'none', 'important');
}
}

document.querySelectorAll('.field').forEach(function(f) {
var texto = f.innerText ? f.innerText.toUpperCase().trim() : "";
var tieneInput = f.querySelector('select, input:not([type="checkbox"]), textarea');

// 1. Batallón
if (!tieneInput && texto.indexOf("BATALLÓN") !== -1) {
alternarVisibilidad(f, esBatallon);
return;
}

// 2. Control de Personas
for (var p = 1; p <= 5; p++) {
var mostrarComida = (!esBatallon && p <= n);
if (!tieneInput && texto.indexOf("PERSONA " + p) !== -1) {
alternarVisibilidad(f, mostrarComida);
}

var inputInterno = f.querySelector('[name^="producto"]');
if (inputInterno) {
var numProd = parseInt(inputInterno.name.replace('producto', ''));
if (numProd >= ((p - 1) * 5) + 1 && numProd <= p * 5) {
alternarVisibilidad(f, mostrarComida);
}
}
}

// 3. Ocultar Adiciones (Checkboxes)
if (f.querySelector('input[type="checkbox"]')) {
alternarVisibilidad(f, mostrarExtras);
}

// 4. Ocultar Título "ADICIONES" y "SALSAS"
if (!tieneInput && (texto.indexOf("ADICION") !== -1 || texto.indexOf("SALSAS") !== -1)) {
alternarVisibilidad(f, mostrarExtras);
}
});

// 5. Ocultar Notas
var notas = document.querySelector('[name="notas"], textarea');
if (notas) {
alternarVisibilidad(notas.closest('.field') || notas.parentElement, mostrarExtras);
}

// 6. Ocultar Botón de Enviar
var btnEnviar = document.querySelector('button[type="submit"], input[type="submit"], .button.submit');
if (btnEnviar) {
alternarVisibilidad(btnEnviar.closest('.actions') || btnEnviar.closest('ul') || btnEnviar.parentElement, mostrarExtras);
}
}

selectorPersonas.addEventListener('change', actualizarBloques);
setTimeout(actualizarBloques, 100);
}

// Lógica de Domicilio
const opcionesPedido = document.querySelectorAll('[name="tipo_pedido"]');
const inputDireccion = document.querySelector('[name="direccion"]');
if (opcionesPedido.length > 0 && inputDireccion && !inputDireccion.dataset.configDir) {
inputDireccion.dataset.configDir = "true";
function revisarDomicilio() {
let tipo = "local";
let radioChecked = document.querySelector('[name="tipo_pedido"]:checked');

if (radioChecked) tipo = radioChecked.value.toLowerCase();
else if (opcionesPedido[0].tagName === 'SELECT') tipo = opcionesPedido[0].value.toLowerCase();
else if (opcionesPedido[0].value) tipo = opcionesPedido[0].value.toLowerCase();

const cont = inputDireccion.closest('.field') || inputDireccion.parentElement;
if (tipo === "domicilio") {
cont.style.removeProperty('display');
inputDireccion.setAttribute("required", "true");
} else {
cont.style.setProperty('display', 'none', 'important');
inputDireccion.removeAttribute("required");
inputDireccion.value = "";
}
}

opcionesPedido.forEach(el => el.addEventListener("change", revisarDomicilio));
revisarDomicilio();
}
}

function limpiarSinBorrarTodo() {
const regex = /\((opcional|optional)\)/gi;
document.querySelectorAll('label, .label, option').forEach(el => {
const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null, false);
let node;
while (node = walker.nextNode()) {
if (regex.test(node.nodeValue)) {
node.nodeValue = node.nodeValue.replace(regex, '').trim();
}
}
});
}

var intentos = 0;
var escaner = setInterval(function() {
inicializarCarrd();
limpiarSinBorrarTodo();
intentos++;
if (intentos > 20) clearInterval(escaner);
}, 500);
})();
