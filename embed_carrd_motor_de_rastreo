<style>
#app-rastreo { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: transparent; display: flex; flex-direction: column; align-items: center; width: 100%; }
.rastreo-container { max-width: 400px; width: 100%; background: white; border-radius: 15px; padding: 30px 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); text-align: center; margin: 20px auto; }
#app-rastreo h2 { color: #856404; margin-top: 0; font-size: 22px; font-weight: 800;}
#app-rastreo p { color: #666; font-size: 14px; }
#turnoInput { width: 80%; padding: 15px; font-size: 24px; text-align: center; border: 2px solid #ffeeba; border-radius: 10px; margin-bottom: 20px; font-weight: bold; color: #721c24; outline: none; }
#turnoInput:focus { border-color: #ffc107; }
.btn-rastreo { background-color: #ffc107; color: #856404; border: none; padding: 15px 30px; font-size: 16px; font-weight: bold; border-radius: 10px; cursor: pointer; width: 100%; transition: 0.2s; }
.btn-rastreo:hover { background-color: #e0a800; }

#resultado { display: none; margin-top: 10px; text-align: left; }
.cliente-hola { font-size: 18px; font-weight: bold; color: #333; text-align: center; margin-bottom: 5px; }
.estado-texto { font-size: 12px; color: #28a745; text-align: center; margin-bottom: 20px; font-weight: bold; height: 15px; }

/* NUEVO CONTENEDOR DE PAGO */
#infoPago { font-size: 16px; font-weight: bold; color: #856404; background: #fff3cd; border: 1px solid #ffeeba; border-radius: 8px; padding: 10px; margin-bottom: 20px; text-align: center; display: none; }
#totalPedido { color: #dc3545; font-size: 18px; }
#metodoPago { font-size: 13px; color: #666; }

.step { display: flex; align-items: center; margin-bottom: 20px; opacity: 0.4; transition: 0.5s all ease; }
.step.active { opacity: 1; font-weight: bold; color: #721c24; transform: scale(1.02); }
.icon { width: 40px; height: 40px; border-radius: 50%; background: #eee; display: flex; justify-content: center; align-items: center; font-size: 20px; margin-right: 15px; transition: 0.5s; }
.active .icon { background: #ffc107; box-shadow: 0 0 10px rgba(255, 193, 7, 0.5); }
.text-step { font-size: 16px; transition: 0.5s; color: #333; margin:0; }
.loader { display: none; margin-top: 15px; font-size: 14px; color: #888; font-style: italic; }
</style>

<div id="app-rastreo">
<div class="rastreo-container" id="box-busqueda">
<h2>🍔 RASTREO DE PEDIDO</h2>
<p>Ingresa el número de turno asignado para ver el estado de tu comida.</p>
<input type="number" id="turnoInput" placeholder="Ej: 4521" autocomplete="off">
<button class="btn-rastreo" onclick="buscarTicket()" id="btnBuscar">Rastrear 🔍</button>
<div class="loader" id="loading">Conectando con la cocina... ⏳</div>
</div>

<div class="rastreo-container" id="resultado">
<div class="cliente-hola" id="saludoCliente">Hola, Cliente</div>
<div class="estado-texto" id="indicadorActualizacion">Actualizado justo ahora</div>

<div id="infoPago">
Total a pagar: <span id="totalPedido">$0</span><br>
<span id="metodoPago">Método: Efectivo</span>
</div>

<div class="step" id="step1"><div class="icon">📝</div><p class="text-step">Pedido Recibido</p></div>
<div class="step" id="step2"><div class="icon">👨‍🍳</div><p class="text-step">Preparando en Cocina</p></div>
<div class="step" id="step3"><div class="icon" id="iconStep3">🛵</div><p class="text-step" id="textStep3">En Camino / Listo</p></div>
<div class="step" id="step4"><div class="icon" id="iconStep4">✅</div><p class="text-step" id="textStep4">Entregado</p></div>

<button class="btn-rastreo" onclick="nuevaBusqueda()" style="margin-top: 20px; background: #eee; color: #333;">Buscar otro ticket</button>
</div>
</div>

<script>
// Tu URL Oficial
const URL_BACKEND = "https://script.google.com/macros/s/AKfycbz0TaWoCMu5b7dmpe_qiRuYfke3SYmLvhvyOT0JqR8scaZplGMvzVWXRx03VJ3VHh8TwQ/exec";

let intervaloRastreo = null;
let turnoActual = "";

function buscarTicket() {
const turno = document.getElementById('turnoInput').value.trim();
if (!turno) { alert("Por favor ingresa un número de turno válido."); return; }

turnoActual = turno;
document.getElementById('btnBuscar').style.display = 'none';
document.getElementById('loading').style.display = 'block';

if (intervaloRastreo) { clearInterval(intervaloRastreo); intervaloRastreo = null; }

ejecutarConsultaApi();
}

function ejecutarConsultaApi() {
const scriptId = 'jsonp-rastreo';
const scriptViejo = document.getElementById(scriptId);
if (scriptViejo) scriptViejo.remove();

const script = document.createElement('script');
script.id = scriptId;

const cacheBuster = new Date().getTime();
script.src = URL_BACKEND + "?mode=api_rastreo&turno=" + turnoActual + "&callback=procesarRespuestaGoogle&t=" + cacheBuster;

script.onerror = function() {
console.error("Error conectando con Google.");
document.getElementById('indicadorActualizacion').innerText = "Error de conexión. Reintentando...";
document.getElementById('btnBuscar').style.display = 'block';
document.getElementById('loading').style.display = 'none';
};

document.body.appendChild(script);
}

window.procesarRespuestaGoogle = function(res) {
if (document.getElementById('box-busqueda').style.display !== 'none') {
mostrarResultadoInicial(res);
} else {
actualizarUI(res);
}
};

function mostrarResultadoInicial(res) {
document.getElementById('btnBuscar').style.display = 'block';
document.getElementById('loading').style.display = 'none';

if (!res.encontrado) {
alert("No encontramos ningún pedido activo con ese número de turno.");
return;
}

document.getElementById('box-busqueda').style.display = 'none';
document.getElementById('resultado').style.display = 'block';
actualizarUI(res);

if (!res.estado.toUpperCase().includes("ENTREGADO") && !res.estado.toUpperCase().includes("ANULADO")) {
intervaloRastreo = setInterval(() => {
document.getElementById('indicadorActualizacion').innerText = "Sincronizando...";
ejecutarConsultaApi();
}, 10000);
}
}

function actualizarUI(res) {
if (!res.encontrado) return;

document.getElementById('indicadorActualizacion').innerText = "Actualizado en tiempo real 🟢";
document.getElementById('saludoCliente').innerText = "Pedido de: " + res.cliente;

document.getElementById('infoPago').style.display = 'block';
document.getElementById('totalPedido').innerText = "$" + (res.total || 0).toLocaleString();
document.getElementById('metodoPago').innerText = "Método: " + (res.metodo || 'EFECTIVO').toUpperCase();

for(let i=1; i<=4; i++) document.getElementById('step'+i).classList.remove('active');
document.getElementById('iconStep4').innerText = "✅";
document.getElementById('textStep4').innerText = "Entregado";

let tipo = res.tipo.toUpperCase();
if (tipo === "LOCAL") {
document.getElementById('iconStep3').innerText = "🛍️";
document.getElementById('textStep3').innerText = "Listo en Barra";
} else if (tipo === "PARA LLEVAR") {
document.getElementById('iconStep3').innerText = "🥡";
document.getElementById('textStep3').innerText = "Empacado y Listo";
} else {
document.getElementById('iconStep3').innerText = "🛵";
document.getElementById('textStep3').innerText = "En Reparto";
}

let est = res.estado.toUpperCase();

if (est.includes("PENDIENTE") || est.includes("POR PAGAR")) {
document.getElementById('step1').classList.add('active');
}
else if (est.includes("EN COCINA")) {
document.getElementById('step1').classList.add('active');
document.getElementById('step2').classList.add('active');
}
else if (est.includes("EN REPARTO") || est.includes("BARRA")) {
document.getElementById('step1').classList.add('active');
document.getElementById('step2').classList.add('active');
document.getElementById('step3').classList.add('active');
}
else if (est.includes("ENTREGADO") || est.includes("ANULADO")) {
document.getElementById('step1').classList.add('active');
document.getElementById('step2').classList.add('active');
document.getElementById('step3').classList.add('active');
document.getElementById('step4').classList.add('active');

if (intervaloRastreo) { clearInterval(intervaloRastreo); intervaloRastreo = null; }
document.getElementById('indicadorActualizacion').innerText = "Pedido finalizado";

if (est.includes("ANULADO")) {
document.getElementById('iconStep4').innerText = "❌";
document.getElementById('textStep4').innerText = "Anulado";
}
}
}

function nuevaBusqueda() {
if (intervaloRastreo) { clearInterval(intervaloRastreo); intervaloRastreo = null; }
document.getElementById('resultado').style.display = 'none';
document.getElementById('box-busqueda').style.display = 'block';
document.getElementById('turnoInput').value = '';
document.getElementById('indicadorActualizacion').innerText = "";
document.getElementById('infoPago').style.display = 'none';
}
</script>
